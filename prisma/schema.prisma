generator client {
  provider = "prisma-client"

  // ⚠️ Exclude the generated directory from version control in .gitignore: /src/generated/prisma
  // https://www.prisma.io/docs/orm/prisma-schema/overview/generators#3-exclude-the-generated-directory-from-version-control
  output        = "../src/generated/prisma"
  // Update your schema.prisma to explicitly include Vercel's platform: "rhel-openssl-3.0.x"
  // This normally isn't an issue, until you try to deploy manually from GitHub Actions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

///////////////////////////////////////////////////////////////////////////
//
//
//
///////////////////////////////////////////////////////////////////////////

model Post {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String   @unique
  body      String
  published Boolean  @default(false)
  // author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // authorId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

enum Role {
  USER
  ADMIN
}

///////////////////////////////////////////////////////////////////////////
//
// All of this gets generated by automatically by using the Better Auth CLI.
// https://www.better-auth.com/docs/concepts/cli
//
//   npx @better-auth/cli@latest generate    
//
///////////////////////////////////////////////////////////////////////////

model User {
  id    String @id
  name  String
  email String

  emailVerified Boolean   @default(false)
  // See WDS at 1:57:40 for allowing various domains from within next.config.ts
  // See Coding In FLow at 1:34:15 https://www.youtube.com/watch?v=w5Emwt3nuV0
  // This generally only matters when using the acutal <Image /> component.
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Where's the password?
  // The password is not stored on the User model. Instead, it lives on the Account model.
  sessions      Session[]
  accounts      Account[]

  ///////////////////////////////////////////////////////////////////////////
  //
  // Additional Fields:
  //
  //   - WDS at 1:49:45
  //   - Coding in Flow at 38:00
  //
  // Added role property. However, I think BETTER-AUTH will still be
  // unaware of it. To inform BETTER-AUTH, do this in lib/auth.ts:
  //
  //   user: {
  //     additionalFields: {
  //       role: { type: 'string', input: false }
  //     }
  //   }
  //
  ///////////////////////////////////////////////////////////////////////////
  role Role @default(USER)

  @@unique([email])
  @@map("users") //^ Changed user -> users
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions") //^ Changed session -> sessions
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts") //^ Changed account -> accounts
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
